{
  "name": "patchproof",
  "version": "0.1.0",
  "description": "Local proof bundles for patches, command receipts, and reviewer handoffs.",
  "type": "module",
  "main": "./dist/src/index.js",
  "bin": {
    "patchproof": "./dist/src/cli.js"
  },
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "dist",
    "docs",
    "scripts/smoke.sh",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "pretest": "npm run build",
    "test": "node --test dist/test/*.test.js",
    "smoke": "bash scripts/smoke.sh",
    "prepack": "npm run build",
    "package:smoke": "npm run build && test -f dist/src/cli.js && test -f dist/src/index.js && npm pack --dry-run",
    "release:check": "npm test && npm run check && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "git",
    "cli",
    "proof",
    "review",
    "testing"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/patchproof.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/patchproof/issues"
  },
  "homepage": "https://github.com/rogerchappel/patchproof#readme"
}
