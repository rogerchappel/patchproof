{
  "name": "patchproof",
  "version": "0.1.0",
  "description": "Local proof bundles for patches, command receipts, and reviewer handoffs.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "patchproof": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs",
    "scripts/smoke.sh",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "pretest": "npm run build",
    "test": "node --test dist/test/*.test.js",
    "smoke": "bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm test && npm run check && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "git",
    "cli",
    "proof",
    "review",
    "testing"
  ],
  "author": "Roger",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
